    /* Logo Animation */
    .jt-logo .ship {
        transform-box: fill-box;
        transform-origin: center;
        animation: jt-thrust 3.4s ease-in-out infinite;
    }
    .jt-logo .flame {
        transform-box: fill-box;
        transform-origin: top center;
