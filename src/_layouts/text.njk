---
layout: base
solo: true
---
<style>
    /* ─── Solo Text Page ─── */
    body {
        background: #fafaf8;
        color: #1a1a1a;
        margin: 0;
        min-height: 100vh;
    }

    .solo-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 8rem 2rem 6rem;
    }

    .solo-title {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 400;
        line-height: 1.15;
        margin: 0 0 4rem;
        color: #0a0a0a;
        letter-spacing: -0.01em;
    }

    .solo-content {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.15rem, 1.8vw, 1.45rem);
        line-height: 1.7;
        color: #1a1a1a;
        max-width: 640px;
    }

    .solo-content p {
        margin: 0 0 1.6rem;
    }

    .solo-content em {
        font-style: italic;
        color: #444;
    }

    .solo-content a {
        color: #1a1a1a;
        text-decoration: underline;
        text-decoration-color: #bbb;
        text-underline-offset: 3px;
    }

    .solo-image-wrap {
        position: relative;
        margin: 5rem auto 0;
        max-width: 720px;
    }
    .solo-image {
        display: block;
        width: 100%;
        max-width: 720px;
        height: auto;
        transition: transform 0.6s ease;
    }
    .rotate-btn {
        position: absolute;
        top: 0.8rem;
        right: 0.8rem;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.3);
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.7);
        font-size: 1.3rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        z-index: 2;
    }
    .rotate-btn:hover {
        border-color: rgba(255,255,255,0.6);
        color: #fff;
    }

    /* ─── Floating Glass Close ─── */
    .solo-close {
        position: fixed;
        top: 1.5rem;
        left: 1.5rem;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #1a1a1a;
        font-family: -apple-system, sans-serif;
        font-size: 22px;
        font-weight: 300;
        z-index: 100;
        transition: all 0.25s ease;
    }

    .solo-close::before {
        content: '×';
        line-height: 1;
        margin-top: -2px;
    }

    @media (hover: hover) {
        .solo-close:hover {
            background: rgba(255, 255, 255, 0.85);
            transform: scale(1.05);
            box-shadow:
                0 12px 40px rgba(0, 0, 0, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 1);
        }
    }

    .solo-close:active {
        transform: scale(0.95);
    }

    @media (max-width: 700px) {
        .solo-page {
            padding: 7rem 1.4rem 4rem;
        }
        .solo-close {
            top: 1rem;
            left: 1rem;
            width: 46px;
            height: 46px;
            font-size: 20px;
        }
    }
</style>

<a href="/texte/" class="solo-close" aria-label="Schließen"></a>

<article class="solo-page">
    <h1 class="solo-title">{{ title | nlToBr | safe }}</h1>

    <div class="solo-content">
        {{ content | safe }}
    </div>

    {% if heroImage %}
    <div class="solo-image-wrap">
        <button class="rotate-btn" id="rotateBtn" aria-label="Bild drehen" title="Bild drehen">↻</button>
        <img src="{{ heroImage }}" alt="Bild zum Text: {{ title }}" loading="lazy" class="solo-image" id="soloImage">
    </div>
    <script>
    (function(){
        var angle = 0;
        var btn = document.getElementById('rotateBtn');
        var img = document.getElementById('soloImage');
        if (btn && img) {
            btn.addEventListener('click', function() {
                angle = (angle + 90) % 360;
                img.style.transform = 'rotate(' + angle + 'deg)';
            });
        }
    })();
    </script>
    {% endif %}
</article>
