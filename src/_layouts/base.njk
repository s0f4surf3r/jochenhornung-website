<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}Jochen Hornung</title>

    <meta name="google-site-verification" content="f13dJEfZlqqMox3rZIfQUUGtqO5QJjmuIrgYIGI5Gb0" />

    <!-- SEO Meta Tags -->
    {% set pageDescription = description or excerpt or "Retro Game Dev · Consciousness Tools · Design · AI Experiments · Berlin. Texte, Werkzeuge und Experimente von Jochen Hornung." %}
    {% set pageImage = heroImage or "/images/og-image.png" %}
    {% set ogType = "article" if tags and "text" in tags else "website" %}
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="Jochen Hornung">
    <link rel="canonical" href="https://jochenhornung.de{{ page.url }}">

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="{{ ogType }}">
    <meta property="og:url" content="https://jochenhornung.de{{ page.url }}">
    <meta property="og:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://jochenhornung.de{{ page.url }}">
    <meta name="twitter:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="twitter:description" content="{{ pageDescription }}">
    <meta property="twitter:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Favicons für alle Browser und Plattformen -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png">
    <!-- favicon.svg entfernt (war 2.2MB) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="manifest" href="/images/site.webmanifest">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Jochen Hornung",
        "url": "https://jochenhornung.de",
        "jobTitle": "Builder · Game Dev · Consciousness Tools",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Berlin",
            "addressCountry": "DE"
        },
        "email": "kontakt@jochenhornung.de",
        "description": "Retro Game Dev · Consciousness Tools · Design · AI Experiments · Berlin. Texte, Werkzeuge und Experimente von Jochen Hornung."
    }
    </script>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        .site-header {
            padding: 3rem 2rem 1rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .site-header h1 {
            font-size: 1.8rem;
            font-weight: 400;
            margin-bottom: 0.3rem;
        }

        .site-header h1 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .site-tagline {
            font-size: 1rem;
            color: #666;
            margin-bottom: 1rem;
            font-family: Georgia, serif;
            font-style: italic;
        }

        .site-nav {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .site-nav a {
            color: #1a1a1a;
            text-decoration: underline;
        }

        .site-nav a.active {
            color: #999;
            text-decoration: none;
        }

        .site-nav span {
            color: #999;
        }

        .content-page {
            padding-top: 1rem;
        }

        .content-page .text-content,
        .content-page .text-excerpt,
        .text-item h3 a {
            font-family: Georgia, serif;
        }

        .text-item h3 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .text-item h3 a:hover {
            text-decoration: underline;
        }

        .site-footer {
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid #eee;
            font-size: 0.9rem;
            color: #666;
        }

        .content-page ~ .site-footer {
            margin-top: 4rem;
        }

        .site-footer a {
            color: #666;
        }
    </style>
</head>
<body>
    {% if page.url != "/" %}
    <header class="site-header">
        <h1><a href="/">Jochen Hornung</a></h1>
        <p class="site-tagline">Retro Game Dev · Consciousness Tools · Design · AI Experiments · Berlin</p>
        <nav class="site-nav">
            <a href="/texte/"{% if page.url.includes("/texte") %} class="active"{% endif %}>Texte</a>
            <span>/</span>
            <a href="/werkzeuge/"{% if page.url.includes("/werkzeuge") %} class="active"{% endif %}>Werkzeuge</a>
            <span>/</span>
            <a href="/kaktus/"{% if page.url.includes("/kaktus") %} class="active"{% endif %}>Streaming</a>
            <span>/</span>
            <a href="/ueber/"{% if page.url.includes("/ueber") or page.url.includes("/coaching") %} class="active"{% endif %}>Über mich</a>
        </nav>
    </header>
    {% endif %}

    {{ content | safe }}

    {% if page.url != "/" %}
    <footer class="site-footer">
        © 2026 Jochen Hornung | <a href="/impressum/">Impressum</a> | <a href="/datenschutz/">Datenschutz</a>
    </footer>
    {% endif %}
</body>
</html>
