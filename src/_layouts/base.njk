<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}Jochen Hornung</title>

    <meta name="google-site-verification" content="f13dJEfZlqqMox3rZIfQUUGtqO5QJjmuIrgYIGI5Gb0" />

    <!-- SEO Meta Tags -->
    {% set pageDescription = description or excerpt or "Design · Consciousness · Apps · AI · Berlin. Texte und Werkzeuge von Jochen Hornung." %}
    {% set pageImage = heroImage or "/images/og-image.png" %}
    {% set ogType = "article" if tags and "text" in tags else "website" %}
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="Jochen Hornung">
    <link rel="canonical" href="https://jochenhornung.de{{ page.url }}">

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="{{ ogType }}">
    <meta property="og:url" content="https://jochenhornung.de{{ page.url }}">
    <meta property="og:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://jochenhornung.de{{ page.url }}">
    <meta name="twitter:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="twitter:description" content="{{ pageDescription }}">
    <meta property="twitter:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Favicons für alle Browser und Plattformen -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png">
    <!-- favicon.svg entfernt (war 2.2MB) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="manifest" href="/images/site.webmanifest">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Jochen Hornung",
        "url": "https://jochenhornung.de",
        "jobTitle": "Design · Consciousness · Apps · AI",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Berlin",
            "addressCountry": "DE"
        },
        "email": "kontakt@jochenhornung.de",
        "description": "Design · Consciousness · Apps · AI · Berlin. Texte und Werkzeuge von Jochen Hornung."
    }
    </script>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        .site-header {
            padding: 3rem 2rem 1rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .site-header h1 {
            font-size: 1.8rem;
            font-weight: 400;
            margin-bottom: 0.3rem;
        }

        .site-header h1 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .site-tagline {
            font-size: 1rem;
            color: #666;
            margin-bottom: 1rem;
            font-family: Georgia, serif;
            font-style: italic;
        }

        .site-nav {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .site-nav a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .site-nav a {
            position: relative;
            display: inline-block;
            transition: color 0.3s, transform 0.3s, font-weight 0.3s, letter-spacing 0.3s, text-shadow 0.3s, font-family 0.1s;
            transform-origin: center;
        }

        /* Texte — Holographic Rainbow Shine */
        .site-nav a[data-nav="texte"]:hover {
            background: linear-gradient(90deg, #06b6d4 0%, #d946ef 35%, #f59e0b 70%, #06b6d4 100%);
            background-size: 200% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shine-flow 2s linear infinite;
            filter: drop-shadow(0 0 8px rgba(217, 70, 239, 0.5));
        }
        @keyframes shine-flow {
            0% { background-position: 200% 0; }
            100% { background-position: -100% 0; }
        }

        /* Apps — Glitch (RGB-Split) */
        .site-nav a[data-nav="apps"]:hover {
            color: #06b6d4;
            animation: glitch 0.3s steps(2) infinite;
            text-shadow:
                2px 0 0 rgba(236, 72, 153, 0.8),
                -2px 0 0 rgba(6, 182, 212, 0.8),
                0 0 12px rgba(6, 182, 212, 0.5);
            letter-spacing: 0.05em;
        }
        @keyframes glitch {
            0% { transform: translate(0); }
            25% { transform: translate(-1px, 1px); }
            50% { transform: translate(1px, -1px); }
            75% { transform: translate(-1px, -1px); }
            100% { transform: translate(1px, 1px); }
        }

        /* J-THRUST — Mega Neon-Magenta */
        .site-nav a[data-nav="jthrust"]:hover {
            color: #fff;
            font-weight: 700;
            letter-spacing: 0.08em;
            transform: scale(1.15);
            text-shadow:
                0 0 4px #ec4899,
                0 0 10px #ec4899,
                0 0 24px #ec4899,
                0 0 48px rgba(236, 72, 153, 0.6);
        }

        /* Streaming — Live Pulse (Amber-Gelb) */
        .site-nav a[data-nav="streaming"]:hover {
            color: #fbbf24;
            animation: live-pulse 1.2s ease-in-out infinite;
            text-shadow:
                0 0 8px rgba(251, 191, 36, 0.9),
                0 0 20px rgba(251, 191, 36, 0.5),
                0 0 40px rgba(245, 158, 11, 0.3);
        }
        @keyframes live-pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.85; transform: scale(1.1); }
        }

        /* Über mich — Ember (glühende Kohle) */
        .site-nav a[data-nav="ueber"]:hover {
            color: #ef4444;
            animation: ember 1.4s ease-in-out infinite;
        }
        @keyframes ember {
            0%, 100% {
                text-shadow:
                    0 0 6px rgba(239, 68, 68, 0.7),
                    0 0 14px rgba(239, 68, 68, 0.3);
                color: #ef4444;
            }
            50% {
                text-shadow:
                    0 0 12px rgba(251, 146, 60, 0.9),
                    0 0 24px rgba(239, 68, 68, 0.5);
                color: #f97316;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .site-nav a, .site-nav a:hover {
                animation: none !important;
                transform: none !important;
                transition: color 0.2s !important;
            }
        }

        .site-nav a.active {
            color: #999;
            text-decoration: none;
        }

        .site-nav span {
            color: #999;
        }

        .content-page {
            padding-top: 1rem;
        }

        .content-page .text-content,
        .content-page .text-excerpt,
        .text-item h3 a {
            font-family: Georgia, serif;
        }

        .text-item h3 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .text-item h3 a:hover {
            text-decoration: underline;
        }

        .site-footer {
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid #eee;
            font-size: 0.9rem;
            color: #666;
        }

        .content-page ~ .site-footer {
            margin-top: 4rem;
        }

        .site-footer a {
            color: #666;
        }

        /* Custom cursor dot — Daria-style (mix-blend-mode: difference) */
        .cursor-dot {
            position: fixed;
            top: 0;
            left: 0;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: #fff;
            pointer-events: none;
            mix-blend-mode: difference;
            z-index: 2147483647;
            opacity: 0;
            transform: translate(-50%, -50%);
            transition: opacity 0.2s ease;
        }
        @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
            .cursor-dot { display: none; }
        }
        html.cursor-dot-active,
        html.cursor-dot-active * {
            cursor: none !important;
        }

        /* Landscape-Warnung nur für Smartphones */
        .orientation-warning {
            display: none;
            position: fixed;
            inset: 0;
            background: #000;
            color: #fff;
            z-index: 99999;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 2rem;
            font-family: -apple-system, 'Helvetica Neue', sans-serif;
        }
        .orientation-message p {
            margin: 0 0 1.4rem;
            font-size: 1.05rem;
            line-height: 1.4;
        }
        .orientation-signature {
            font-style: italic;
            opacity: 0.75;
        }
        @media (orientation: landscape) and (max-height: 480px) and (hover: none) {
            .orientation-warning { display: flex; }
        }
    </style>
</head>
<body>
    <div class="orientation-warning" role="alert">
      <div class="orientation-message">
        <p>Please switch to portrait mode<br>to get the full experience.</p>
        <p class="orientation-signature">In love,<br>Jochen</p>
      </div>
    </div>

    {% if page.url != "/" and not solo %}
    <header class="site-header">
        <h1><a href="/">Jochen Hornung</a></h1>
        <p class="site-tagline">Design · Consciousness · Apps · AI · Berlin</p>
        <nav class="site-nav">
            <a href="/texte/" data-nav="texte"{% if page.url.includes("/texte") %} class="active"{% endif %}>Texte</a>
            <span>/</span>
            <a href="/apps/" data-nav="apps"{% if page.url.includes("/apps") or page.url.includes("/werkzeuge") %} class="active"{% endif %}>Apps</a>
            <span>/</span>
            <a href="/j-thrust/" data-nav="jthrust"{% if page.url.includes("/j-thrust") %} class="active"{% endif %}>J-THRUST</a>
            <span>/</span>
            <a href="/kaktus/" data-nav="streaming"{% if page.url.includes("/kaktus") %} class="active"{% endif %}>Streaming</a>
            <span>/</span>
            <a href="/ueber/" data-nav="ueber"{% if page.url.includes("/ueber") or page.url.includes("/coaching") %} class="active"{% endif %}>Über mich</a>
        </nav>
    </header>
    {% endif %}

    {{ content | safe }}

    {% if page.url != "/" and not solo %}
    <footer class="site-footer">
        © 2026 Jochen Hornung | <a href="/impressum/">Impressum</a> | <a href="/datenschutz/">Datenschutz</a>
    </footer>
    {% endif %}

    <script>
    /* Reload startet immer ganz oben + ganz links — kein Scroll-Restore. Plus: Chat-Widget schließen falls .open im BFCache hängt */
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    window.addEventListener('pageshow', () => {
      window.scrollTo(0, 0);
      document.getElementById('chatWidget')?.classList.remove('open');
    });
    </script>
    <div class="cursor-dot" aria-hidden="true"></div>
    <script>
    (() => {
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const dot = document.querySelector('.cursor-dot');
        if (!dot) return;
        document.documentElement.classList.add('cursor-dot-active');
        const move = (e) => {
            dot.style.opacity = '1';
            dot.style.transform = `translate(-50%, -50%) translate(${e.clientX}px, ${e.clientY}px)`;
        };
        document.addEventListener('mousemove', move, { passive: true });
        document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; });
    })();
    </script>
</body>
</html>
