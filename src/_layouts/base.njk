<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}Jochen Hornung</title>

    <meta name="google-site-verification" content="f13dJEfZlqqMox3rZIfQUUGtqO5QJjmuIrgYIGI5Gb0" />

    <!-- SEO Meta Tags -->
    {% set pageDescription = description or excerpt or "Design · Consciousness · Apps · AI · Berlin. Texte und Werkzeuge von Jochen Hornung." %}
    {% set pageImage = heroImage or "/images/og-image.png" %}
    {% set ogType = "article" if tags and "text" in tags else "website" %}
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="Jochen Hornung">
    <link rel="canonical" href="https://jochenhornung.de{{ page.url }}">

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="{{ ogType }}">
    <meta property="og:url" content="https://jochenhornung.de{{ page.url }}">
    <meta property="og:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://jochenhornung.de{{ page.url }}">
    <meta name="twitter:title" content="{% if title %}{{ title }} - {% endif %}Jochen Hornung">
    <meta property="twitter:description" content="{{ pageDescription }}">
    <meta property="twitter:image" content="https://jochenhornung.de{{ pageImage }}">

    <!-- Favicons für alle Browser und Plattformen -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png">
    <!-- favicon.svg entfernt (war 2.2MB) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="manifest" href="/images/site.webmanifest">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Jochen Hornung",
        "url": "https://jochenhornung.de",
        "jobTitle": "Design · Consciousness · Apps · AI",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Berlin",
            "addressCountry": "DE"
        },
        "email": "kontakt@jochenhornung.de",
        "description": "Design · Consciousness · Apps · AI · Berlin. Texte und Werkzeuge von Jochen Hornung."
    }
    </script>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        .site-header {
            padding: 3rem 2rem 1rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .site-header h1 {
            font-size: 1.8rem;
            font-weight: 400;
            margin-bottom: 0.3rem;
        }

        .site-header h1 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .site-tagline {
            font-size: 1rem;
            color: #666;
            margin-bottom: 1rem;
            font-family: Georgia, serif;
            font-style: italic;
        }

        .site-nav {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .site-nav a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .site-nav a {
            position: relative;
            display: inline-block;
            transition: letter-spacing 0.25s;
        }
        .site-nav a > span {
            display: inline-block;
            transition: color 0.2s, transform 0.2s, text-shadow 0.2s;
        }

        /* Texte — LILA: Buchstaben rotieren 360° (gestaffelt) */
        .site-nav a[data-nav="texte"]:hover { letter-spacing: 0.08em; }
        .site-nav a[data-nav="texte"]:hover > span {
            color: #a855f7;
            font-weight: 800;
            animation: spin-letter 1s ease-in-out infinite;
            animation-delay: calc(var(--i) * 0.06s);
        }
        @keyframes spin-letter {
            0%, 100% { transform: rotateY(0) scale(1.1); }
            50% { transform: rotateY(360deg) scale(1.2); }
        }

        /* Apps — BUNT: jeder Buchstabe andere Farbe + Hop-Welle */
        .site-nav a[data-nav="apps"]:hover { letter-spacing: 0.1em; }
        .site-nav a[data-nav="apps"]:hover > span {
            color: hsl(calc(var(--i) * 75), 85%, 55%);
            font-weight: 800;
            animation: hop-letter 0.7s ease-in-out infinite;
            animation-delay: calc(var(--i) * 0.08s);
        }
        @keyframes hop-letter {
            0%, 100% { transform: translateY(0) scale(1.1) rotate(0); }
            50% { transform: translateY(-10px) scale(1.2) rotate(-12deg); }
        }

        /* J-THRUST — GELB WEGSPRITZEND: Buchstaben fliegen weg + zurück */
        .site-nav a[data-nav="jthrust"]:hover { letter-spacing: 0.12em; }
        .site-nav a[data-nav="jthrust"]:hover > span {
            color: #facc15;
            font-weight: 900;
            animation: explode-back 1.2s ease-in-out infinite;
            animation-delay: calc(var(--i) * 0.05s);
        }
        @keyframes explode-back {
            0%, 100% { transform: translate(0, 0) rotate(0) scale(1.15); }
            40% { transform: translate(0, -16px) rotate(25deg) scale(1.3); }
            60% { transform: translate(0, -16px) rotate(-20deg) scale(1.3); }
        }

        /* Streaming — BLAUGRÜN: Sinus-Welle */
        .site-nav a[data-nav="streaming"]:hover { letter-spacing: 0.08em; }
        .site-nav a[data-nav="streaming"]:hover > span {
            color: #14b8a6;
            font-weight: 700;
            animation: wave-letter 1s ease-in-out infinite;
            animation-delay: calc(var(--i) * 0.1s);
        }
        @keyframes wave-letter {
            0%, 100% { transform: translateY(0) scale(1.1); }
            50% { transform: translateY(-10px) rotate(8deg) scale(1.15); }
        }

        /* Über mich — Farb-Flicker zwischen Rot/Orange */
        .site-nav a[data-nav="ueber"]:hover { letter-spacing: 0.06em; }
        .site-nav a[data-nav="ueber"]:hover > span {
            font-weight: 700;
            animation: flicker-letter 0.8s ease-in-out infinite;
            animation-delay: calc(var(--i) * 0.12s);
        }
        @keyframes flicker-letter {
            0%, 100% { color: #ef4444; transform: translateY(0) scale(1.05); }
            50% { color: #f97316; transform: translateY(-3px) scale(1.15); }
        }

        @media (prefers-reduced-motion: reduce) {
            .site-nav a, .site-nav a > span,
            .site-nav a:hover, .site-nav a:hover > span {
                animation: none !important;
                transform: none !important;
                transition: color 0.2s !important;
            }
        }

        .site-nav a.active {
            color: #999;
            text-decoration: none;
        }

        .site-nav span {
            color: #999;
        }

        .content-page {
            padding-top: 1rem;
        }

        .content-page .text-content,
        .content-page .text-excerpt,
        .text-item h3 a {
            font-family: Georgia, serif;
        }

        .text-item h3 a {
            color: #1a1a1a;
            text-decoration: none;
        }

        .text-item h3 a:hover {
            text-decoration: underline;
        }

        .site-footer {
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid #eee;
            font-size: 0.9rem;
            color: #666;
        }

        .content-page ~ .site-footer {
            margin-top: 4rem;
        }

        .site-footer a {
            color: #666;
        }

        /* Custom cursor dot — Daria-style (mix-blend-mode: difference) */
        .cursor-dot {
            position: fixed;
            top: 0;
            left: 0;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: #fff;
            pointer-events: none;
            mix-blend-mode: difference;
            z-index: 2147483647;
            opacity: 0;
            transform: translate(-50%, -50%);
            transition: opacity 0.2s ease;
        }
        @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
            .cursor-dot { display: none; }
        }
        html.cursor-dot-active,
        html.cursor-dot-active * {
            cursor: none !important;
        }

        /* Landscape-Warnung nur für Smartphones */
        .orientation-warning {
            display: none;
            position: fixed;
            inset: 0;
            background: #000;
            color: #fff;
            z-index: 99999;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 2rem;
            font-family: -apple-system, 'Helvetica Neue', sans-serif;
        }
        .orientation-message p {
            margin: 0 0 1.4rem;
            font-size: 1.05rem;
            line-height: 1.4;
        }
        .orientation-signature {
            font-style: italic;
            opacity: 0.75;
        }
        @media (orientation: landscape) and (max-height: 480px) and (hover: none) {
            .orientation-warning { display: flex; }
        }
    </style>
</head>
<body>
    <div class="orientation-warning" role="alert">
      <div class="orientation-message">
        <p>Please switch to portrait mode<br>to get the full experience.</p>
        <p class="orientation-signature">In love,<br>Jochen</p>
      </div>
    </div>

    {% if page.url != "/" and not solo %}
    <header class="site-header">
        <h1><a href="/">Jochen Hornung</a></h1>
        <p class="site-tagline">Design · Consciousness · Apps · AI · Berlin</p>
        <nav class="site-nav">
            <a href="/texte/" data-nav="texte"{% if page.url.includes("/texte") %} class="active"{% endif %}>Texte</a>
            <span>/</span>
            <a href="/apps/" data-nav="apps"{% if page.url.includes("/apps") or page.url.includes("/werkzeuge") %} class="active"{% endif %}>Apps</a>
            <span>/</span>
            <a href="/j-thrust/" data-nav="jthrust"{% if page.url.includes("/j-thrust") %} class="active"{% endif %}>J-THRUST</a>
            <span>/</span>
            <a href="/kaktus/" data-nav="streaming"{% if page.url.includes("/kaktus") %} class="active"{% endif %}>Streaming</a>
            <span>/</span>
            <a href="/ueber/" data-nav="ueber"{% if page.url.includes("/ueber") or page.url.includes("/coaching") %} class="active"{% endif %}>Über mich</a>
        </nav>
    </header>
    {% endif %}

    {{ content | safe }}

    {% if page.url != "/" and not solo %}
    <footer class="site-footer">
        © 2026 Jochen Hornung | <a href="/impressum/">Impressum</a> | <a href="/datenschutz/">Datenschutz</a>
    </footer>
    {% endif %}

    <script>
    /* Reload startet immer ganz oben + ganz links — kein Scroll-Restore. Plus: Chat-Widget schließen falls .open im BFCache hängt */
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    window.addEventListener('pageshow', () => {
      window.scrollTo(0, 0);
      document.getElementById('chatWidget')?.classList.remove('open');
    });
    /* Nav-Buchstaben in Spans wickeln für per-letter-Animation */
    document.querySelectorAll('.site-nav a[data-nav]').forEach(a => {
      const text = a.textContent;
      a.innerHTML = text.split('').map((ch, i) => {
        const safe = ch === ' ' ? '&nbsp;' : ch;
        return `<span style="--i:${i}">${safe}</span>`;
      }).join('');
    });
    </script>
    <div class="cursor-dot" aria-hidden="true"></div>
    <script>
    (() => {
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const dot = document.querySelector('.cursor-dot');
        if (!dot) return;
        document.documentElement.classList.add('cursor-dot-active');
        const move = (e) => {
            dot.style.opacity = '1';
            dot.style.transform = `translate(-50%, -50%) translate(${e.clientX}px, ${e.clientY}px)`;
        };
        document.addEventListener('mousemove', move, { passive: true });
        document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; });
    })();
    </script>
</body>
</html>
