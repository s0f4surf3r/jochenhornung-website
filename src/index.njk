  }
}

.ctrl-btn:active {
  transform: scale(0.95);
}

.ctrl-btn.active {
  border-color: var(--sand-accent);
  color: var(--sand-accent);
}

/* Sound wave bars */
.sound-bars {
  display: none;
  align-items: flex-end;
  gap: 2px;
  height: 16px;
}

.ctrl-btn.active .sound-off { display: none; }
.ctrl-btn.active .sound-bars { display: flex; }
.ctrl-btn:not(.active) .sound-bars { display: none; }
.ctrl-btn:not(.active) .sound-off { display: block; }

.sound-bars span {
  display: block;
  width: 3px;
  background: var(--sand-accent);
  border-radius: 1.5px;
  animation: soundWave 1.2s ease-in-out infinite;
}

.sound-bars span:nth-child(1) { height: 4px; animation-delay: 0s; }
.sound-bars span:nth-child(2) { height: 10px; animation-delay: 0.15s; }
.sound-bars span:nth-child(3) { height: 6px; animation-delay: 0.3s; }
.sound-bars span:nth-child(4) { height: 12px; animation-delay: 0.45s; }

@keyframes soundWave {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1); }
}

@media (prefers-reduced-motion: reduce) {
  .sound-bars span { animation: none; }
}

