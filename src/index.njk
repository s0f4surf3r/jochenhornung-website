<style>
/* ══════════════════════════════════════
   SAND-WELT — Hell, warm, einladend.
   Kontrast-Achse: 35% (weich, nicht laut)
   Noise-Grain für analoge Wärme.
   ══════════════════════════════════════ */

:root {
  --bg: #000000;
  --text: #e0e0e0;
  --dim: #555;
  --amber: #ffb000;
  --cyan: #00e5ff;
  --magenta: #ff00aa;
  --green: #00ff41;
  --card-bg: rgba(255, 176, 0, 0.03);
  --card-border: rgba(255, 176, 0, 0.15);
  --pixel-size: 4px;
  /* Sand fallbacks for inner pages */
  --sand-bg: #f5f0e6;
  --sand-text: #1a1816;
  --sand-text-muted: #6b6054;
  --sand-text-dim: #9a8e7e;
  --sand-accent: #b8942a;
  --sand-border: #e0d8cc;
  --sand-card: #faf8f4;
}

html { scroll-behavior: smooth; }

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  .reveal { opacity: 1 !important; transform: none !important; }
}

body {
  background-color: #000000 !important;
  color: var(--text) !important;
  -webkit-tap-highlight-color: transparent;
  overflow-x: hidden;
  position: relative;
}

/* Particle Canvas — hinter allem Content */
#pixel-rain {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 10;
  opacity: 1;
}

/* ── COLOR BAR ── */
.color-bar {
  height: 4px;
  background: linear-gradient(90deg, var(--green), var(--cyan), var(--amber), var(--magenta), var(--cyan), var(--green), var(--cyan), var(--amber), var(--magenta), var(--cyan), var(--green));
  background-size: 200% 100%;
  animation: colorBarFlow 8s linear infinite;
  position: relative;
  z-index: 10;
}

@keyframes colorBarFlow {
  0% { background-position: 0% 0; }
  100% { background-position: 200% 0; }
}

@media (prefers-reduced-motion: reduce) {
  .color-bar { animation: none; }
}

/* ── HERO ── */
.hero-home {
  position: relative;
  background: #000000;
}

.hero-home, .hero-claim-wrap, .hero-nav {
  background: #000000;
}

.hero-image {
  width: 100%;
  display: block;
  overflow: hidden;
  position: relative;
  z-index: 0;
}

.hero-image img {
  width: 100%;
  height: auto;
  display: block;
  opacity: 0.85;
}

.hero-claim-wrap {
  padding: 3rem 4rem 4rem;
  max-width: 100%;
  margin: 0 auto;
  text-align: center;
}

.hero-claim {
  font-family: 'Courier New', 'Courier', monospace;
  font-size: clamp(1.4rem, 3.2vw, 2.6rem);
  font-weight: 700;
  line-height: 1.1;
  color: inherit;
  margin: 0;
  cursor: default;
  user-select: none;
  position: relative;
  display: inline-block;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-shadow: none; /* Jedes Claim-Wort hat eigene text-shadow */
  text-wrap: balance;
}

/* Drei Farben für die drei Claim-Wörter */
.claim-design { color: var(--amber); text-shadow: 0 0 20px rgba(255,176,0,0.4), 0 0 60px rgba(255,176,0,0.15); }
.claim-consciousness { color: var(--green); text-shadow: 0 0 20px rgba(0,255,65,0.4), 0 0 60px rgba(0,255,65,0.15); }
.claim-tools { color: var(--cyan); text-shadow: 0 0 20px rgba(0,229,255,0.4), 0 0 60px rgba(0,229,255,0.15); }
.claim-ai { color: var(--magenta); text-shadow: 0 0 20px rgba(255,0,170,0.4), 0 0 60px rgba(255,0,170,0.15); }
.claim-sep { color: rgba(255,255,255,0.2); }

/* Scanlines als Pseudo-Element ÜBER dem Text */
.hero-claim::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    to bottom,
    transparent 0px,
    transparent 2px,
    rgba(0, 0, 0, 0.5) 2px,
    rgba(0, 0, 0, 0.5) 4px
  );
  pointer-events: none;
}

.hero-sub {
  font-family: 'Courier New', monospace;
  font-size: 0.95rem;
  letter-spacing: 0.08em;
  color: var(--cyan);
  margin: 1.2rem 0 0 0;
  opacity: 0.6;
}

.hero-sub-dim {
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  line-height: 1.85;
  color: var(--text);
  margin: 1.2rem 0 0 0;
}

.hero-nav {
  display: flex;
  gap: 1.3rem;
  flex-wrap: wrap;
  align-items: center;
  font-family: 'Courier New', monospace;
  font-size: 0.95rem;
  max-width: none;
  margin: 0;
  padding: 0.6rem 2rem;
}

.hero-nav .nav-home {
  font-weight: 600;
  color: var(--sand-text);
  margin-right: auto;
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
}

.nav-logo {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(255, 176, 0, 0.3), 0 0 20px rgba(255, 176, 0, 0.15);
}

.social-icon {
  opacity: 0.5;
  transition: opacity 0.2s, color 0.2s;
  min-width: 44px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

@media (hover: hover) {
  .social-icon:hover { opacity: 1; color: var(--amber) !important; }
}

/* Hamburger */
.nav-burger {
  display: none;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
}

.nav-burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text);
  transition: transform 0.3s, opacity 0.3s;
}

.nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.open span:nth-child(2) { opacity: 0; }
.nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.nav-links {
  display: contents;
}

@media (max-width: 900px) {
  .nav-burger { display: flex; }

  .nav-links {
    display: none;
    flex-direction: column;
    width: 100%;
    padding: 1rem 0;
    gap: 0.2rem;
  }

  .nav-links.open { display: flex; }

  .nav-links .nav-sep { display: none; }

  .nav-links a {
    padding: 0.8rem 0;
    font-size: 1.1rem;
  }

  .hero-nav {
    flex-wrap: wrap;
    padding-left: 2rem;
    padding-right: 2rem;
  }
}

.hero-nav a {
  color: var(--text);
  text-decoration: none;
  padding: 0.5rem 0;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  transition: color 0.2s;
}

@media (hover: hover) {
  .hero-nav a:hover {
    color: var(--amber);
    text-shadow: 0 0 12px rgba(255, 176, 0, 0.5), 0 0 30px rgba(255, 176, 0, 0.2);
  }
}

.hero-nav a:active {
  color: var(--amber);
  text-shadow: 0 0 12px rgba(255, 176, 0, 0.5), 0 0 30px rgba(255, 176, 0, 0.2);
}

.hero-nav .nav-sep {
  color: rgba(255,255,255,0.25);
  user-select: none;
}

.hero-nav .nav-home {
  color: var(--text);
}

/* ── SECTIONS ── */
.section {
  position: relative;
  padding: 5rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
}

/* ── PIXEL DIVIDER ── */
.pixel-divider {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin: 0;
  padding: 3rem 2rem;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

.pixel-divider span {
  width: var(--pixel-size);
  height: var(--pixel-size);
  background: var(--green);
  opacity: 0.15;
  display: inline-block;
  transition: opacity 0.3s, box-shadow 0.3s;
}

.pixel-divider span:nth-child(3n) { background: var(--cyan); }
.pixel-divider span:nth-child(7n) { background: var(--magenta); }
.pixel-divider span:nth-child(5n) { background: var(--amber); }

.pixel-divider span.kit-active {
  opacity: 1;
  box-shadow: 0 0 8px currentColor, 0 0 16px currentColor;
}

.pixel-divider span.kit-fade1 { opacity: 0.6; box-shadow: 0 0 4px currentColor; }
.pixel-divider span.kit-fade2 { opacity: 0.35; }

.section-label {
  font-family: 'Courier New', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--green);
  margin: 0 0 1.5rem 0;
  text-align: center;
}

.section-heading {
  font-family: 'Courier New', monospace;
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 700;
  line-height: 1.4;
  color: var(--amber);
  margin: 0 0 1.5rem 0;
  text-align: center;
  text-shadow: 0 0 20px rgba(255, 176, 0, 0.15);
}

.section-text {
  font-family: 'Courier New', monospace;
  font-size: 1rem;
  line-height: 1.85;
  color: var(--text);
  max-width: 900px;
  margin: 0 auto 2.5rem;
  text-align: center;
}

/* ── CARDS ── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  perspective: 800px;
}

.card {
  background: #0e1420;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 2rem 1.8rem;
  text-decoration: none;
  color: #f4f6ff;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  display: block;
  text-align: center;
  min-height: 44px;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 20%, rgba(0,210,255,0.06) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s;
}

@media (hover: hover) {
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(0,210,255,0.2);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 30px rgba(0,210,255,0.06);
  }
  .card:hover::before { opacity: 1; }
}

.card:focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 2px;
}

.card:active {
  transform: scale(0.97);
}

.card-icon {
  margin-bottom: 1rem;
  display: block;
  color: rgba(244,246,255,0.4);
}

.card-logo {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  margin: 0 auto 1rem;
  display: block;
  object-fit: contain;
  position: relative;
  z-index: 1;
}

.card-title {
  font-family: -apple-system, 'Helvetica Neue', sans-serif;
  font-size: 1.05rem;
  font-weight: 600;
  margin: 0 0 0.6rem 0;
  position: relative;
  z-index: 1;
}

.card-desc {
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  line-height: 1.75;
  color: rgba(244,246,255,0.5);
  margin: 0;
  position: relative;
  z-index: 1;
}

/* ── TEXTE (Terminal Style) ── */
.terminal-quote {
  font-family: 'Courier New', monospace;
  font-size: clamp(1.3rem, 3vw, 2rem);
  line-height: 1.5;
  color: var(--amber);
  text-align: center;
  margin: 0 auto 2rem;
  max-width: 600px;
  text-shadow: 0 0 15px rgba(255, 176, 0, 0.2);
}

.terminal-link {
  display: block;
  font-family: 'Courier New', monospace;
  font-size: 1rem;
  color: var(--green);
  text-decoration: none;
  text-align: center;
  transition: color 0.2s;
}

@media (hover: hover) {
  .terminal-link:hover {
    color: var(--cyan);
    text-shadow: 0 0 10px rgba(0, 229, 255, 0.3);
  }
}

/* ── STREAMING ── */
.streaming-teaser {
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.5rem;
  text-decoration: none;
  color: var(--text);
}

@media (hover: hover) {
  .streaming-teaser:hover { border-color: var(--amber); }
}

.streaming-teaser:active { border-color: var(--amber); }

.streaming-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  flex-shrink: 0;
}

.streaming-info p {
  font-family: 'Courier New', monospace;
  font-size: 0.95rem;
  line-height: 1.75;
  color: var(--text);
  margin: 0.5rem 0 0 0;
}

.streaming-badge {
  display: inline-block;
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--green);
  border: 1px solid var(--green);
  border-radius: 4px;
  padding: 0.25rem 0.6rem;
}

/* ── LINKS ── */
.text-link {
  color: var(--cyan);
  text-decoration: none;
  border-bottom: 1px solid rgba(0, 229, 255, 0.3);
  padding-bottom: 1px;
  transition: border-color 0.2s;
  font-family: 'Courier New', monospace;
  font-size: 1rem;
}

@media (hover: hover) {
  .text-link:hover { border-color: var(--cyan); }
}

/* ── DIVIDER ── */
.section-divider {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 4rem;
}

.section-divider hr {
  border: none;
  border-top: 1px solid var(--sand-border);
  margin: 0;
}

/* ── FOOTER ── */
.home-footer {
  position: relative;
  padding: 3rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
  border-top: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  font-family: 'Courier New', monospace;
  font-size: 0.8rem;
  color: var(--text);
}

.home-footer a {
  color: var(--text);
  text-decoration: none;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  transition: color 0.2s;
}

@media (hover: hover) {
  .home-footer a:hover { color: var(--cyan); }
}

.footer-links { display: flex; gap: 1.5rem; }

/* Scroll reveal disabled */

