<script>
(function() {
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var audioCtx, gainNode, isPlaying = false;

  /* AudioContext SOFORT bei erster Gesture + WAV vorladen */
  var shatterBuf = null;
  var shatterLoading = false;

  function ensureAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    /* WAV sofort vorladen */
    if (!shatterBuf && !shatterLoading) {
      shatterLoading = true;
      fetch('/images/shatter.wav')
        .then(function(r) { return r.arrayBuffer(); })
        .then(function(b) { return audioCtx.decodeAudioData(b); })
        .then(function(decoded) { shatterBuf = decoded; })
        .catch(function() { shatterLoading = false; });
    }
    return audioCtx;
  }
  document.addEventListener('click', ensureAudio, { once: true });
  document.addEventListener('touchstart', ensureAudio, { once: true });

  /* ═══ KNIGHT RIDER PIXEL DIVIDERS + KITT Sound ═══ */
  if (!reducedMotion) {
    /* KITT sweep oscillator — leise, nur wenn sichtbar */
    var kittOsc, kittGain, kittCtx;

    document.querySelectorAll('.pixel-divider').forEach(function(div, idx) {
      var spans = div.querySelectorAll('span');
      var len = spans.length;
      if (len === 0) return;
      var pos = 0;
      var dir = 1;

      /* Sound nur für den ersten sichtbaren Divider starten wenn User interagiert */
      if (idx === 0) {
        document.addEventListener('click', function initKitt() {
          if (kittCtx) return;
          ensureAudio();
          kittCtx = audioCtx;

          /* Mehrere Oscillatoren für fetten KITT-Sound */
          kittOsc = kittCtx.createOscillator();
          kittOsc.type = 'sine';
          kittOsc.frequency.value = 200;

          var kittOsc2 = kittCtx.createOscillator();
          kittOsc2.type = 'sine';
          kittOsc2.frequency.value = 400; /* Oktave drüber */

          var kittOsc3 = kittCtx.createOscillator();
          kittOsc3.type = 'sawtooth';
          kittOsc3.frequency.value = 100; /* Brumm-Basis */

          kittGain = kittCtx.createGain();
          kittGain.gain.value = 0;

          var gain2 = kittCtx.createGain();
          gain2.gain.value = 0;

          var gain3 = kittCtx.createGain();
          gain3.gain.value = 0;

          /* Bandpass für den "Wuuusch"-Charakter */
          var bp = kittCtx.createBiquadFilter();
          bp.type = 'bandpass';
          bp.frequency.value = 500;
          bp.Q.value = 2;

          var master = kittCtx.createGain();
          master.gain.value = 1;

          kittOsc.connect(kittGain);
          kittOsc2.connect(gain2);
          kittOsc3.connect(gain3);
          kittGain.connect(bp);
          gain2.connect(bp);
          gain3.connect(bp);
          bp.connect(master);
          master.connect(kittCtx.destination);

          kittOsc.start();
          kittOsc2.start();
          kittOsc3.start();

          /* Speichere für Sweep-Update */
          kittOsc._osc2 = kittOsc2;
          kittOsc._osc3 = kittOsc3;
          kittOsc._gain2 = gain2;
          kittOsc._gain3 = gain3;
          kittOsc._bp = bp;
          kittOsc._master = master;
        }, { once: true });
      }

      setInterval(function() {
        spans.forEach(function(s) {
          s.classList.remove('kit-active', 'kit-fade1', 'kit-fade2');
        });
        if (spans[pos]) spans[pos].classList.add('kit-active');
        if (spans[pos - 1]) spans[pos - 1].classList.add('kit-fade1');
        if (spans[pos + 1]) spans[pos + 1].classList.add('kit-fade1');
        if (spans[pos - 2]) spans[pos - 2].classList.add('kit-fade2');
        if (spans[pos + 2]) spans[pos + 2].classList.add('kit-fade2');

        /* KITT sweep — alle Oscillatoren folgen Position */
        if (kittOsc && kittGain && idx === 0) {
          var ratio = pos / len;
          var baseFreq = 150 + ratio * 500;
          kittOsc.frequency.value = baseFreq;
          if (kittOsc._osc2) kittOsc._osc2.frequency.value = baseFreq * 2;
          if (kittOsc._osc3) kittOsc._osc3.frequency.value = baseFreq * 0.5;
          if (kittOsc._bp) kittOsc._bp.frequency.value = baseFreq * 1.5;

          /* Sound an sobald gescrollt wurde, aus wenn wieder ganz oben (Landing) */
          var scrolled = window.scrollY > 50;
          var vol = (scrolled && isPlaying) ? 0.012 : 0;
          kittGain.gain.value = vol;
          if (kittOsc._gain2) kittOsc._gain2.gain.value = vol * 0.4;
          if (kittOsc._gain3) kittOsc._gain3.gain.value = vol * 0.2;
        }

        pos += dir;
        if (pos >= len - 1) dir = -1;
        if (pos <= 0) dir = 1;
      }, 60);
    });
  }

  /* ═══ LETTER DISPERSION ═══ */
  var nameEl = document.querySelector('.hero-claim');
  if (nameEl && !reducedMotion) {
    /* Claim-Word-Spans (.claim-design etc.) bewahren, nur Text darin in Letter-Spans wrappen */
    var claimWords = nameEl.querySelectorAll('.claim-word');
    if (claimWords.length) {
      claimWords.forEach(function(cw) {
        var txt = cw.textContent;
        cw.innerHTML = txt.split('').map(function(ch) {
          if (ch === ' ') return ' ';
          return '<span class="letter">' + ch + '</span>';
        }).join('');
      });
      /* Separatoren (.claim-sep) behalten wir, brauchen keine Letter-Wrap */
    } else {
      /* Fallback falls keine .claim-word Spans da sind */
      var original = nameEl.textContent;
      nameEl.innerHTML = original.split(' ').map(function(word) {
        if (word === '') return '';
        var letters = word.split('').map(function(ch) {
          return '<span class="letter">' + ch + '</span>';
        }).join('');
        return '<span class="word">' + letters + '</span>';
      }).join(' ');
    }

    var scattered = false;
    var returnTimer;

    function playShatter() {
      /* Tennis-Hit synthetisiert: kurzer Noise-Burst durch Bandpass + Sub-Pop */
      if (!audioCtx) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      var now = audioCtx.currentTime;

      /* (1) Noise-Burst — der "Thwack" der Saiten */
      var bufferSize = audioCtx.sampleRate * 0.18;
      var noiseBuf = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
      var data = noiseBuf.getChannelData(0);
      for (var i = 0; i < bufferSize; i++) {
        data[i] = (Math.random() * 2 - 1);
      }
      var noise = audioCtx.createBufferSource();
      noise.buffer = noiseBuf;

      /* Bandpass — Center bei 1200 Hz, schmal — die Saiten-Klangfarbe */
      var bp = audioCtx.createBiquadFilter();
      bp.type = 'bandpass';
      bp.frequency.value = 1200;
      bp.Q.value = 1.4;

      /* Envelope: instant attack, schneller Decay */
      var noiseGain = audioCtx.createGain();
      noiseGain.gain.setValueAtTime(0.001, now);
      noiseGain.gain.exponentialRampToValueAtTime(0.6, now + 0.001);
      noiseGain.gain.exponentialRampToValueAtTime(0.001, now + 0.16);

      noise.connect(bp); bp.connect(noiseGain); noiseGain.connect(audioCtx.destination);
      noise.start(now); noise.stop(now + 0.18);

      /* (2) Sub-Pop — der "Body" des Aufpralls (Filz auf Saiten) */
      var sub = audioCtx.createOscillator();
      sub.type = 'sine';
      sub.frequency.setValueAtTime(180, now);
      sub.frequency.exponentialRampToValueAtTime(60, now + 0.08);

      var subGain = audioCtx.createGain();
      subGain.gain.setValueAtTime(0.001, now);
      subGain.gain.exponentialRampToValueAtTime(0.5, now + 0.002);
      subGain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);

      sub.connect(subGain); subGain.connect(audioCtx.destination);
      sub.start(now); sub.stop(now + 0.12);
    }

    function scatter(withSound) {
      if (withSound !== false) playShatter();
      var letters = nameEl.querySelectorAll('.letter');
      /* Bullet-Time: jeder Buchstabe fliegt gestaffelt */
      letters.forEach(function(l, i) {
        var delay = i * 25; /* 25ms Versatz pro Buchstabe */
        setTimeout(function() {
          var angle = Math.random() * Math.PI * 2;
          var dist = 80 + Math.random() * 160;
          var x = Math.cos(angle) * dist;
          var y = Math.sin(angle) * dist;
          var r = (Math.random() - 0.5) * 90;
          var s = 0.3 + Math.random() * 0.7;
          l.style.transition = 'transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.5s ease';
          l.style.transform = 'translate(' + x + 'px,' + y + 'px) rotate(' + r + 'deg) scale(' + s + ')';
          l.style.opacity = (0.1 + Math.random() * 0.3).toString();
        }, delay);
      });
      /* Sog zurück nach 1.5s — auch gestaffelt */
      setTimeout(function() {
        letters.forEach(function(l, i) {
          setTimeout(function() {
            l.style.transition = 'transform 1.2s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.8s ease';
            l.style.transform = '';
            l.style.opacity = '';
          }, i * 15);
        });
        setTimeout(function() { scattered = false; }, letters.length * 15 + 1200);
      }, 1500);
      scattered = true;
    }

    function unscatter() {
      nameEl.querySelectorAll('.letter').forEach(function(l) {
        l.style.transition = 'transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease';
        l.style.transform = '';
        l.style.opacity = '';
      });
      scattered = false;
    }

    /* ═══ CLAIM SOUND PADS ═══ */
    /* Jedes Claim-Wort hat seinen eigenen Sound */
    var claimSounds = {};
    var soundFiles = {
      'claim-design': '/sounds/design.mp3',
      'claim-consciousness': '/sounds/consciousness.mp3',
      'claim-tools': '/sounds/tools.mp3',
      'claim-ai': '/sounds/ai.mp3'
    };

    function playClaimSound(className) {
      ensureAudio();
      if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
      if (!claimSounds[className]) {
        /* Lade Sound beim ersten Tap */
        fetch(soundFiles[className]).then(function(r) { return r.arrayBuffer(); }).then(function(buf) {
          audioCtx.decodeAudioData(buf, function(decoded) {
            claimSounds[className] = decoded;
            triggerSound(decoded);
          });
        });
      } else {
        triggerSound(claimSounds[className]);
      }
    }

    function triggerSound(buffer) {
      var src = audioCtx.createBufferSource();
      src.buffer = buffer;
      var g = audioCtx.createGain();
      g.gain.value = 0.5;
      src.connect(g);
      g.connect(audioCtx.destination);
      src.start();
    }

    claimWords.forEach(function(cw) {
      cw.style.cursor = 'pointer';
      cw.style.webkitTapHighlightColor = 'transparent';

      /* Visuelles Feedback */
      function flash() {
        cw.style.filter = 'brightness(2)';
        cw.style.transition = 'filter 0.08s';
        setTimeout(function() {
          cw.style.filter = '';
          cw.style.transition = 'filter 0.4s';
        }, 100);
      }

      /* Touch */
      cw.addEventListener('touchstart', function(e) {
        e.preventDefault();
        var cls = Array.from(cw.classList).find(function(c) { return c.startsWith('claim-'); });
        if (cls) playClaimSound(cls);
        flash();
      }, { passive: false });

      /* Click (Desktop) */
      cw.addEventListener('click', function() {
        var cls = Array.from(cw.classList).find(function(c) { return c.startsWith('claim-'); });
        if (cls) playClaimSound(cls);
        flash();
      });
    });

    /* Desktop: hover scatter MIT sound */
    nameEl.addEventListener('mouseenter', function() {
      clearTimeout(returnTimer);
      scatter();
    });
    nameEl.addEventListener('mouseleave', function() {
      unscatter();
    });

    /* Touch: tap to scatter, auto-return */
    nameEl.addEventListener('touchstart', function(e) {
      e.preventDefault();
      clearTimeout(returnTimer);
      if (scattered) {
        unscatter();
      } else {
        scatter();
        returnTimer = setTimeout(unscatter, 2500);
      }
    }, { passive: false });
  }

  /* ═══ BANNER 3D TILT + PARALLAX ═══ */
  if (!reducedMotion) {
    var bannerImg = document.querySelector('.hero-image img');
    var heroImage = document.querySelector('.hero-image');
    if (bannerImg && heroImage) {
      /* Parallax on scroll */
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            var scrollY = window.pageYOffset;
            var rect = heroImage.getBoundingClientRect();
            if (rect.bottom > 0) {
              bannerImg.style.transform = 'translateY(' + (scrollY * 0.08) + 'px)';
            }
            ticking = false;
          });
          ticking = true;
        }
      });

      /* Ripple disabled — was blocking all sections below hero */
    }
  }

  /* ═══ CARD TILT ═══ */
  if (!reducedMotion && window.matchMedia('(hover: hover)').matches) {
    document.querySelectorAll('.card').forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = 'translateY(-2px) rotateY(' + (x * 4) + 'deg) rotateX(' + (-y * 4) + 'deg)';
      });
      card.addEventListener('mouseleave', function() {
        card.style.transform = '';
      });
    });
  }

  /* ═══ HEARTBEAT-LOOP ═══ */
  var soundBtn = document.getElementById('soundToggle');
  var heartbeatAudio = document.getElementById('heartbeatAudio');
  var headphoneHint = document.getElementById('headphoneHint');

  function fadeAudio(audio, targetVol, durationMs) {
    var startVol = audio.volume;
    var startTime = performance.now();
    function tick() {
      var t = Math.min(1, (performance.now() - startTime) / durationMs);
      audio.volume = Math.max(0, Math.min(1, startVol + (targetVol - startVol) * t));
      if (t < 1) requestAnimationFrame(tick);
    }
    tick();
  }

  if (soundBtn && heartbeatAudio) {
    /* Bei Refresh immer OFF — kein Restore aus localStorage */
    heartbeatAudio.volume = 0;

    soundBtn.addEventListener('click', function() {
      if (isPlaying) {
        /* OFF: fade out, dann pause */
        fadeAudio(heartbeatAudio, 0, 600);
        setTimeout(function() { if (!isPlaying) heartbeatAudio.pause(); }, 700);
        isPlaying = false;
        soundBtn.classList.remove('active');
        if (headphoneHint) headphoneHint.classList.remove('show');
      } else {
        /* ON: starten + sanft hochfaden */
        heartbeatAudio.volume = 0;
        heartbeatAudio.play().catch(function() {});
        fadeAudio(heartbeatAudio, 0.35, 1500);
        isPlaying = true;
        soundBtn.classList.add('active');
        /* Dezenter Headphone-Hint nur beim ersten ON-Click pro Browser-Session */
        if (headphoneHint && !localStorage.getItem('jh-headphone-hint-shown')) {
          headphoneHint.classList.add('show');
          localStorage.setItem('jh-headphone-hint-shown', '1');
          setTimeout(function() { headphoneHint.classList.remove('show'); }, 3500);
        }
      }
    });
  }
  /* ═══ HAMBURGER MENU ═══ */
  var burger = document.getElementById('navBurger');
  var navLinks = document.getElementById('navLinks');
  if (burger && navLinks) {
    burger.addEventListener('click', function() {
      var open = burger.classList.toggle('open');
      navLinks.classList.toggle('open');
      burger.setAttribute('aria-expanded', open);
    });
  }

  /* ═══ CARD FLIP ═══ */
  document.querySelectorAll('.card').forEach(function(card) {
    var angle = 0;
    card.addEventListener('click', function(e) {
      e.preventDefault();
      angle += 360;
      card.style.transform = 'rotateY(' + angle + 'deg)';
      card.style.transition = 'transform 0.8s cubic-bezier(0.23, 1, 0.32, 1)';
      /* Nach Dreh zur Werkzeuge-Seite navigieren */
      setTimeout(function() { window.location.href = card.href; }, 900);
    });
  });

  /* ═══ PIXEL RAIN ═══ */
  var pCanvas = document.getElementById('pixel-rain');
  if (pCanvas && !reducedMotion) {
    var pctx = pCanvas.getContext('2d');
    var pw, ph;
    function resizeP() { pw = pCanvas.width = window.innerWidth; ph = pCanvas.height = window.innerHeight; }
    resizeP();
    window.addEventListener('resize', resizeP);
    var pxls = [];
    var pcols = ['#00ff41', '#00e5ff', '#ff00aa', '#ffb000'];
    function animP() {
      pctx.clearRect(0, 0, pw, ph);
      if (Math.random() < 0.4) pxls.push({ x: Math.random() * pw, y: -3, sz: Math.random() * 3 + 1, sp: Math.random() * 0.5 + 0.15, c: pcols[Math.floor(Math.random() * pcols.length)], o: Math.random() * 0.2 + 0.05 });
      for (var i = pxls.length - 1; i >= 0; i--) {
        var p = pxls[i]; p.y += p.sp;
        pctx.globalAlpha = p.o; pctx.fillStyle = p.c;
        pctx.fillRect(p.x, p.y, p.sz, p.sz);
        if (p.y > ph) pxls.splice(i, 1);
      }
      requestAnimationFrame(animP);
    }
    animP();
  }

  /* ═══ CHAT WIDGET ═══ */
  var chatWidget = document.getElementById('chatWidget');
  var chatBtn = document.getElementById('chatBtn');
  var chatClose = document.getElementById('chatClose');
  var chatForm = document.getElementById('chatForm');
  var chatInput = document.getElementById('chatInput');
  var chatMessages = document.getElementById('chatMessages');
  var chatHistory = [];

  if (chatBtn && chatWidget) {
    chatBtn.addEventListener('click', function() {
      chatWidget.classList.toggle('open');
      if (chatWidget.classList.contains('open')) {
        setTimeout(function() { chatInput.focus(); }, 350);
      }
    });

    chatClose.addEventListener('click', function() {
      chatWidget.classList.remove('open');
    });

    chatForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var msg = chatInput.value.trim();
      if (!msg) return;

      /* User message */
      var userDiv = document.createElement('div');
      userDiv.className = 'chat-msg user';
      userDiv.textContent = msg;
      chatMessages.appendChild(userDiv);
      chatInput.value = '';

      /* Typing indicator */
      var typingDiv = document.createElement('div');
      typingDiv.className = 'chat-msg assistant typing';
      typingDiv.textContent = '...';
      chatMessages.appendChild(typingDiv);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      /* Send to backend */
      var currentLang = window.__getLang ? window.__getLang() : 'de';
      var fallbackErr = currentLang === 'en'
        ? 'Connection error. Email Jochen directly: kontakt@jochenhornung.de'
        : 'Verbindungsfehler. Schreib mir direkt: kontakt@jochenhornung.de';
      var apiErr = currentLang === 'en' ? 'Connection error.' : 'Fehler bei der Verbindung.';

      fetch('https://jochenhornung-chat.jthrust.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history: chatHistory, lang: currentLang })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        typingDiv.remove();
        var ansDiv = document.createElement('div');
        ansDiv.className = 'chat-msg assistant';
        ansDiv.textContent = data.answer || apiErr;
        chatMessages.appendChild(ansDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;

        chatHistory.push({ role: 'user', content: msg });
        chatHistory.push({ role: 'assistant', content: data.answer });
      })
      .catch(function() {
        typingDiv.remove();
        var errDiv = document.createElement('div');
        errDiv.className = 'chat-msg assistant';
        errDiv.textContent = fallbackErr;
        chatMessages.appendChild(errDiv);
      });
    });
  }

  /* ═══ LANGUAGE TOGGLE ═══ */
  var langBtn = document.getElementById('langToggle');
  var _saved = localStorage.getItem('jochenhornung-lang');
  var lang = _saved || ((navigator.language || 'de').toLowerCase().startsWith('de') ? 'de' : 'en');

  function updateLangBtn() {
    if (langBtn) langBtn.textContent = lang.toUpperCase();
  }

  function pickTranslation(value) {
    if (!value) return null;
    var parts = value.split('|');
    return lang === 'en' && parts.length > 1 ? parts[1] : parts[0];
  }

  function applyLang() {
    document.documentElement.lang = lang;
    document.querySelectorAll('[data-i18n]').forEach(function(el) {
      var t = pickTranslation(el.getAttribute('data-i18n'));
      if (t !== null) el.textContent = t;
    });
    document.querySelectorAll('[data-i18n-aria]').forEach(function(el) {
      var t = pickTranslation(el.getAttribute('data-i18n-aria'));
      if (t !== null) el.setAttribute('aria-label', t);
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
      var t = pickTranslation(el.getAttribute('data-i18n-placeholder'));
      if (t !== null) el.setAttribute('placeholder', t);
    });
    /* document.title + meta description */
    var titleMap = {
      de: 'Design · Consciousness Apps · AI - Jochen Hornung',
      en: 'AI · Apps · Design · Consciousness — Jochen Hornung'
    };
    var descMap = {
      de: 'Jochen Hornung – Builder, Autor, Mensch. Berlin. Texte über das Menschsein, digitale Werkzeuge für emotionale Selbsterkenntnis.',
      en: 'Jochen Hornung — builder, writer, human. Berlin. Writing on being human, digital tools for emotional self-awareness.'
    };
    document.title = titleMap[lang];
    var metaDesc = document.querySelector('meta[name="description"]');
    if (metaDesc) metaDesc.setAttribute('content', descMap[lang]);
  }

  applyLang();
  updateLangBtn();

  if (langBtn) {
    langBtn.addEventListener('click', function() {
      lang = lang === 'de' ? 'en' : 'de';
      localStorage.setItem('jochenhornung-lang', lang);
      updateLangBtn();
      applyLang();
    });
  }

  /* expose for chat */
  window.__getLang = function() { return lang; };

  /* ═══ LIVE COLOR PICKER (Dev Tool) ═══ */
  /* Aktivieren mit ?picker in der URL */
  if (location.search.indexOf('picker') !== -1) {
    var palette = [
      { name: 'Green',   hex: '#00ff41', rgb: '0,255,65' },
      { name: 'Cyan',    hex: '#00e5ff', rgb: '0,229,255' },
      { name: 'Magenta', hex: '#ff00aa', rgb: '255,0,170' },
      { name: 'Amber',   hex: '#ffb000', rgb: '255,176,0' },
      { name: 'White',   hex: '#e0e0e0', rgb: '224,224,224' }
    ];
    var saved = localStorage.getItem('claim-color') || 'Green';
    function applyClaimColor(name) {
      var c = palette.find(function(x){return x.name===name;});
      if (!c) return;
      document.documentElement.style.setProperty('--claim-color', c.hex);
      document.documentElement.style.setProperty('--claim-glow', 'rgba('+c.rgb+',0.3)');
      document.documentElement.style.setProperty('--claim-glow-far', 'rgba('+c.rgb+',0.1)');
      localStorage.setItem('claim-color', name);
    }
    applyClaimColor(saved);
    var panel = document.createElement('div');
    panel.style.cssText = 'position:fixed;bottom:80px;right:20px;background:#000;border:1px solid #333;padding:1rem;z-index:9999;font-family:monospace;font-size:12px;color:#fff;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,0.5)';
    panel.innerHTML = '<div style="margin-bottom:0.6rem;opacity:0.6">CLAIM COLOR</div>';
    palette.forEach(function(c) {
      var b = document.createElement('button');
      b.textContent = c.name;
      b.style.cssText = 'display:block;width:100%;margin:4px 0;padding:8px 12px;background:'+c.hex+';color:#000;border:none;border-radius:4px;cursor:pointer;font-family:monospace;font-weight:700;text-align:left';
      b.onclick = function(){ applyClaimColor(c.name); };
      panel.appendChild(b);
    });
    document.body.appendChild(panel);
  }
})();

/* ═══ LIVE EDIT CAROUSEL ═══ */
(function() {
  /* Aktiviert per ?edit ODER Tap auf Avatar */
  var avatarEl = document.querySelector('.nav-logo');
  var editActive = location.search.includes('edit');

  function initEdit() {
    if (document.getElementById('editBar')) return;
    editActive = true;
    /* Vertikale Position der 4 Hauptelemente: Nav · Hero · Claim · KITT-Divider */
    var controls = [
      { label: 'Nav ↕', type: 'range', target: '.hero-nav', prop: 'paddingTop', min: 0, max: 100, def: 10, unit: 'px' },
      { label: 'Hero-Bild ↕', type: 'range', target: '.hero-image', prop: 'marginTop', min: 0, max: 250, def: 48, unit: 'px' },
      { label: 'Claim ↕', type: 'range', target: '.hero-claim-wrap', prop: 'marginTop', min: 0, max: 250, def: 32, unit: 'px' },
      { label: 'KITT-Divider ↕', type: 'range', target: '.pixel-divider', prop: 'marginTop', min: 0, max: 400, def: 0, unit: 'px' },
    ];

    /* Draggable Bubble — verschiebbar, expandiert zum Slider */
    var bubble = document.createElement('div');
    bubble.id = 'editBar';
    bubble.style.cssText = 'position:fixed;top:90px;left:12px;z-index:99999;font:12px monospace;touch-action:none';

    /* Bubble-Button (zusammengeklappt) */
    var bubbleBtn = document.createElement('div');
    bubbleBtn.style.cssText = 'width:48px;height:48px;border-radius:50%;background:#ffb000;color:#000;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;cursor:grab;box-shadow:0 2px 12px rgba(255,176,0,0.4)';
    bubbleBtn.textContent = '⚙';

    /* Expanded Panel */
    var expandedPanel = document.createElement('div');
    expandedPanel.style.cssText = 'display:none;background:rgba(10,10,15,0.95);border:1px solid #333;border-radius:12px;padding:10px;backdrop-filter:blur(10px);width:260px;margin-bottom:8px';

    var lblEl = document.createElement('div');
    lblEl.style.cssText = 'font-size:10px;color:#ffb000;margin-bottom:6px;letter-spacing:1px;text-align:center';

    var inputWrap = document.createElement('div');
    inputWrap.style.cssText = 'display:flex;align-items:center;gap:6px';

    var prevBtn = document.createElement('button');
    prevBtn.textContent = '◀';
    prevBtn.style.cssText = 'background:none;border:1px solid #555;color:#ccc;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:12px;flex-shrink:0';

    var sliderEl = document.createElement('input');
    sliderEl.style.cssText = 'flex:1;accent-color:#ffb000;cursor:pointer';

    var nextBtn = document.createElement('button');
    nextBtn.textContent = '▶';
    nextBtn.style.cssText = prevBtn.style.cssText;

    var valEl = document.createElement('span');
    valEl.style.cssText = 'color:#ffb000;font-size:11px;min-width:36px;text-align:right';

    inputWrap.appendChild(prevBtn);
    inputWrap.appendChild(sliderEl);
    inputWrap.appendChild(valEl);
    inputWrap.appendChild(nextBtn);
    expandedPanel.appendChild(lblEl);
    expandedPanel.appendChild(inputWrap);

    bubble.appendChild(expandedPanel);
    bubble.appendChild(bubbleBtn);

    var expanded = false;
    bubbleBtn.addEventListener('click', function(e) {
      if (e.target._dragged) return;
      expanded = !expanded;
      expandedPanel.style.display = expanded ? 'block' : 'none';
      bubbleBtn.textContent = expanded ? '✕' : '⚙';
    });

    /* Drag */
    var dragX, dragY, startX, startY, dragging = false;
    function onStart(e) {
      dragging = true;
      bubbleBtn._dragged = false;
      var t = e.touches ? e.touches[0] : e;
      dragX = t.clientX - bubble.offsetLeft;
      dragY = t.clientY - bubble.offsetTop;
      startX = t.clientX; startY = t.clientY;
      bubbleBtn.style.cursor = 'grabbing';
    }
    function onMove(e) {
      if (!dragging) return;
      e.preventDefault();
      var t = e.touches ? e.touches[0] : e;
      bubble.style.left = (t.clientX - dragX) + 'px';
      bubble.style.top = (t.clientY - dragY) + 'px';
      bubble.style.right = 'auto';
      if (Math.abs(t.clientX - startX) > 5 || Math.abs(t.clientY - startY) > 5) bubbleBtn._dragged = true;
    }
    function onEnd() { dragging = false; bubbleBtn.style.cursor = 'grab'; }
    bubbleBtn.addEventListener('mousedown', onStart);
    bubbleBtn.addEventListener('touchstart', onStart, { passive: false });
    document.addEventListener('mousemove', onMove);
    document.addEventListener('touchmove', onMove, { passive: false });
    document.addEventListener('mouseup', onEnd);
    document.addEventListener('touchend', onEnd);

    var closeBtn = { addEventListener: function(){} }; /* Compat */
    var bar = bubble;

    /* Filter: nur echte Controls (keine Headings) */
    var realControls = controls.filter(function(c) { return c.type !== 'heading'; });
    var idx = 0;

    function applyControl(c, value) {
      var els = document.querySelectorAll(c.target);
      if (c.type === 'color') {
        els.forEach(function(el) {
          el.style[c.prop] = value;
          el.style.textShadow = '0 0 20px ' + value + '66, 0 0 60px ' + value + '26';
        });
      } else {
        var val = c.divisor ? (value / c.divisor) : value;
        var unit = c.divisor ? '' : (c.unit === '%' ? '' : (c.unit || 'px'));
        if (c.unit === '%') val = value / 100;
        els.forEach(function(el) {
          el.style[c.prop] = val + unit;
          if (c.alsoBottom) el.style.paddingBottom = val + unit;
          if (c.alsoH) el.style.height = val + unit;
        });
      }
    }

    function showControl(i) {
      var c = realControls[i];
      lblEl.textContent = (i + 1) + '/' + realControls.length + '  ' + c.label;
      if (c.type === 'color') {
        sliderEl.type = 'color';
        sliderEl.min = ''; sliderEl.max = ''; sliderEl.step = '';
        sliderEl.value = c.def;
        valEl.textContent = '';
      } else {
        sliderEl.type = 'range';
        sliderEl.min = c.min;
        sliderEl.max = c.max;
        sliderEl.value = c.def;
        sliderEl.step = c.step || 1;
        valEl.textContent = c.def + (c.unit || '');
      }
      sliderEl.oninput = function() {
        applyControl(c, sliderEl.value);
        if (c.type !== 'color') valEl.textContent = sliderEl.value + (c.unit || '');
      };
    }

    prevBtn.addEventListener('click', function() { idx = (idx - 1 + realControls.length) % realControls.length; showControl(idx); });
    nextBtn.addEventListener('click', function() { idx = (idx + 1) % realControls.length; showControl(idx); });

    /* Speichern-Button */
    var saveBtn = document.createElement('button');
    saveBtn.textContent = '💾';
    saveBtn.style.cssText = 'background:none;border:1px solid #555;color:#ccc;width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:16px;flex-shrink:0';
    saveBtn.addEventListener('click', function() {
      /* Alle geänderten Werte sammeln */
      var values = {};
      realControls.forEach(function(c) {
        var el = document.querySelector(c.target);
        if (el) {
          var val = el.style[c.prop];
          if (val) values[c.label] = { target: c.target, prop: c.prop, value: val };
        }
      });
      var device = window.innerWidth + 'x' + window.innerHeight + ' ' + (navigator.userAgent.match(/iPhone|iPad|Macintosh/) || ['unknown'])[0];
      var payload = {
        device: device,
        viewport: window.innerWidth + 'x' + window.innerHeight,
        dpr: window.devicePixelRatio,
        timestamp: new Date().toISOString(),
        values: values
      };
      var json = JSON.stringify(payload, null, 2);

      /* 1. localStorage für Persistenz auf diesem Gerät */
      localStorage.setItem('jochenhornung-edit-' + window.innerWidth, json);

      /* 2. Per Mail verschicken */
      var subject = 'Live Edit ' + device + ' ' + new Date().toLocaleString('de');
      var body = json;
      window.location.href = 'mailto:jochen.hornung@me.com?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      saveBtn.textContent = '✓';
      setTimeout(function() { saveBtn.textContent = '💾'; }, 2000);
    });
    bar.appendChild(saveBtn);

    /* CSS-Export-Button → Zwischenablage */
    var cssBtn = document.createElement('button');
    cssBtn.textContent = '📋';
    cssBtn.title = 'Aktuelle Werte als CSS in Zwischenablage kopieren';
    cssBtn.style.cssText = 'background:none;border:1px solid #555;color:#ccc;width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:16px;flex-shrink:0;margin-left:6px';
    cssBtn.addEventListener('click', function() {
      /* Werte gruppieren nach selector → property */
      var bySelector = {};
      realControls.forEach(function(c) {
        var el = document.querySelector(c.target);
        if (!el) return;
        var val = el.style[c.prop];
        if (!val) return;
        if (!bySelector[c.target]) bySelector[c.target] = {};
        var cssProp = c.prop.replace(/[A-Z]/g, function(m) { return '-' + m.toLowerCase(); });
        bySelector[c.target][cssProp] = val;
        if (c.alsoBottom) {
          var bottomProp = cssProp.replace('-top', '-bottom');
          bySelector[c.target][bottomProp] = val;
        }
        if (c.alsoH) bySelector[c.target]['height'] = val;
      });
      /* Media-Query basierend auf viewport */
      var w = window.innerWidth;
      var mq;
      if (w <= 480) mq = '@media (max-width: 480px)';
      else if (w <= 743) mq = '@media (max-width: 743px)';
      else if (w <= 900) mq = '@media (min-width: 744px) and (max-width: 900px)';
      else if (w <= 1300) mq = '@media (min-width: 901px) and (max-width: 1300px)';
      else mq = '@media (min-width: 1301px)';
      /* CSS bauen */
      var lines = [];
      lines.push('/* Live-Edit @ ' + window.innerWidth + '×' + window.innerHeight + ' (DPR ' + window.devicePixelRatio + ') — ' + new Date().toISOString() + ' */');
      lines.push(mq + ' {');
      Object.keys(bySelector).forEach(function(sel) {
        var props = bySelector[sel];
        var inner = Object.keys(props).map(function(p) { return '    ' + p + ': ' + props[p] + ';'; }).join('\n');
        lines.push('  ' + sel + ' {\n' + inner + '\n  }');
      });
      lines.push('}');
      var cssText = lines.join('\n');
      /* In Zwischenablage */
      var copy = function(t) {
        try {
          navigator.clipboard.writeText(t);
        } catch(e) {
          var ta = document.createElement('textarea');
          ta.value = t; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove();
        }
      };
      copy(cssText);
      cssBtn.textContent = '✓';
      setTimeout(function() { cssBtn.textContent = '📋'; }, 1600);
    });
    bar.appendChild(cssBtn);

    /* Gespeicherte Werte NUR wiederherstellen wenn Edit aktiv ist (nicht bei normalem Besuch) */

    showControl(0);
    document.body.appendChild(bar);
  }

  /* Avatar-Tap aktiviert Edit */
  if (avatarEl) {
    avatarEl.addEventListener('click', function(e) {
      e.preventDefault();
      if (editActive) { var b = document.getElementById('editBar'); if (b) b.remove(); editActive = false; }
      else initEdit();
    });
  }

  /* ?edit in URL → sofort aktivieren */
  if (location.search.includes('edit')) initEdit();
})();
</script>
