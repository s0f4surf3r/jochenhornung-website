  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.05em;
}

/* ── CHAT WIDGET ── */
.chat-widget {
  position: fixed;
  bottom: 5rem;
  left: auto;
  right: 1.5rem;
  width: 340px;
  max-width: calc(100vw - 2rem);
  box-sizing: border-box;
  max-height: 450px;
  background: #0e1420;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  z-index: 200;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px) scale(0.95);
  pointer-events: none;
  transition: opacity 0.3s, transform 0.3s;
}

.chat-widget.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
  pointer-events: auto;
  transition: opacity 0.3s, transform 0.3s;
}

.chat-header {
  padding: 0.8rem 1rem;
  font-family: 'Courier New', monospace;
  font-size: 0.8rem;
  color: var(--green);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-close {
  font-size: 1.2rem;
  color: var(--dim);
  cursor: pointer;
}

.chat-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  max-height: 320px;
}

.chat-msg {
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  line-height: 1.65;
  padding: 0.6rem 0.8rem;
  border-radius: 8px;
  max-width: 90%;
}

.chat-msg.user {
  background: rgba(0, 229, 255, 0.1);
  color: var(--cyan);
  align-self: flex-end;
  border: 1px solid rgba(0, 229, 255, 0.15);
}

.chat-msg.assistant {
  background: rgba(255, 176, 0, 0.06);
  color: var(--text);
  align-self: flex-start;
  border: 1px solid rgba(255, 176, 0, 0.1);
}

.chat-msg.typing {
  color: var(--dim);
  font-style: italic;
}

.chat-input-wrap {
  display: flex;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 0;
}

.chat-input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text);
  font-family: 'Courier New', monospace;
  font-size: 16px; /* min 16px verhindert iOS Safari Auto-Zoom beim Focus */
  padding: 0.8rem 1rem;
  outline: none;
}

.chat-input::placeholder { color: var(--dim); }

.chat-send {
  background: transparent;
  border: none;
  color: var(--amber);
  font-size: 1.2rem;
  padding: 0.8rem 1rem;
  cursor: pointer;
  font-family: 'Courier New', monospace;
}

@media (max-width: 480px) {
  .chat-widget {
    left: 1rem;
    right: 1rem;
    width: auto;
    bottom: 4rem;
  }
}

/* ── CARD TILT ── */
@media (hover: hover) {
  .card {
    transform-style: preserve-3d;
    perspective: 800px;
  }
}

.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0;
  margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
  white-space: nowrap; border: 0;
}

