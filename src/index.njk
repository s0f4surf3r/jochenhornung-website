/* ── LETTER DISPERSION ── */
.word {
  display: inline-block;
  white-space: nowrap;
}
.letter {
  display: inline-block;
  transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.8s ease;
  will-change: transform, opacity;
}

/* ── PARALLAX ── */
.hero-image {
  overflow: hidden;
}

.hero-image img {
  will-change: transform;
  transition: none;
}

/* ── FLOATING CONTROLS ── */
/* Toggles: Sound links, Chat rechts (Lang ausgeblendet bis EN übersetzt ist) */
.floating-controls { display: contents; }
#langToggle { display: none !important; }
#soundToggle { position: fixed; bottom: 1.5rem; left: 1.5rem; z-index: 100; }
#chatBtn { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 100; }

.ctrl-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1.5px solid rgba(255, 255, 255, 0.12);
  background: transparent;
  color: var(--dim);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  transition: border-color 0.3s, color 0.3s;
  -webkit-tap-highlight-color: transparent;
}

@media (hover: hover) {
  .ctrl-btn:hover {
    border-color: var(--sand-accent);
    color: var(--sand-text);
  }
}

.ctrl-btn:active {
  transform: scale(0.95);
}

.ctrl-btn.active {
  border-color: var(--amber);
  color: var(--amber);
}

/* Sound-Button wabern wenn inaktiv — Aufmerksamkeit */
#soundToggle:not(.active) {
  animation: soundPulse 3s ease-in-out infinite;
}

@keyframes soundPulse {
  0%, 100% { border-color: rgba(255, 255, 255, 0.12); }
  50% { border-color: rgba(255, 176, 0, 0.5); box-shadow: 0 0 12px rgba(255, 176, 0, 0.15); }
}

#soundToggle.active {
  animation: none;
}

@media (prefers-reduced-motion: reduce) {
  #soundToggle:not(.active) { animation: none; }
}

/* Sound wave bars */
.sound-bars {
  display: none;
  align-items: flex-end;
  gap: 2px;
  height: 16px;
}

.ctrl-btn.active .sound-off { display: none; }
.ctrl-btn.active .sound-bars { display: flex; }
.ctrl-btn:not(.active) .sound-bars { display: none; }
.ctrl-btn:not(.active) .sound-off { display: block; }

.sound-bars span {
  display: block;
  width: 3px;
  background: var(--sand-accent);
  border-radius: 1.5px;
  animation: soundWave 1.2s ease-in-out infinite;
}

.sound-bars span:nth-child(1) { height: 4px; animation-delay: 0s; }
.sound-bars span:nth-child(2) { height: 10px; animation-delay: 0.15s; }
.sound-bars span:nth-child(3) { height: 6px; animation-delay: 0.3s; }
.sound-bars span:nth-child(4) { height: 12px; animation-delay: 0.45s; }

@keyframes soundWave {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1); }
}

@media (prefers-reduced-motion: reduce) {
  .sound-bars span { animation: none; }
}

/* Headphone-Hint — dezenter Toast neben dem Sound-Button */
.headphone-hint {
  position: fixed;
  bottom: calc(1.5rem + 11px);
  left: calc(1.5rem + 44px + 12px);
  background: rgba(20, 20, 30, 0.85);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  color: rgba(255, 255, 255, 0.85);
  font-family: 'Courier New', monospace;
  font-size: 11px;
  letter-spacing: 0.04em;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  z-index: 99;
  pointer-events: none;
  opacity: 0;
  transform: translateX(-8px);
  transition: opacity 0.4s ease, transform 0.4s ease;
  white-space: nowrap;
}
.headphone-hint.show { opacity: 1; transform: translateX(0); }
@media (max-width: 743px) {
  .headphone-hint {
    bottom: calc(env(safe-area-inset-bottom, 0px) + 0.5rem + 11px);
    left: calc(0.8rem + 44px + 8px);
  }
}
@media (max-width: 480px) and (orientation: portrait) {
  .headphone-hint {
    top: calc(env(safe-area-inset-top, 0px) + 230px + 11px);
    left: 60px;
    bottom: auto;
  }
}

/* Lang toggle */
