  .hero-claim { white-space: normal; font-size: 38px; letter-spacing: 0; }
  .hero-claim-wrap { padding-top: 35px; padding-bottom: 61px; padding-left: 2rem; padding-right: 2rem; }
  .claim-word { display: block; text-align: center; margin-bottom: 0; }
  .claim-sep { display: none; }
