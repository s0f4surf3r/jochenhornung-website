<script>
(function() {
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ═══ SCROLL REVEAL ═══ */
  if (reducedMotion) {
    document.querySelectorAll('.reveal').forEach(function(el) { el.classList.add('visible'); });
  } else {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });
  }

  /* ═══ LETTER DISPERSION ═══ */
  var nameEl = document.querySelector('.hero-claim');
  if (nameEl && !reducedMotion) {
    var original = nameEl.textContent;
    nameEl.innerHTML = original.split('').map(function(ch) {
      if (ch === ' ') return ' ';
      if (ch === '\n') return '<br>';
      return '<span class="letter">' + ch + '</span>';
    }).join('');

    var scattered = false;
    var returnTimer;

    /* Glass shatter sound via Web Audio */
    function playShatter() {
      try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var duration = 0.4;
        var buf = ctx.createBuffer(1, ctx.sampleRate * duration, ctx.sampleRate);
        var data = buf.getChannelData(0);
        for (var i = 0; i < data.length; i++) {
          var t = i / ctx.sampleRate;
          var env = Math.exp(-t * 12);
          data[i] = (Math.random() * 2 - 1) * env * 0.15;
          /* Helle Glassplitter-Resonanz */
          data[i] += Math.sin(t * 4800) * env * 0.04;
          data[i] += Math.sin(t * 7200) * env * 0.02;
        }
        var src = ctx.createBufferSource();
        src.buffer = buf;
        var hp = ctx.createBiquadFilter();
        hp.type = 'highpass';
        hp.frequency.value = 2000;
        src.connect(hp);
        hp.connect(ctx.destination);
        src.start();
        setTimeout(function() { ctx.close(); }, 600);
      } catch(e) {}
    }

    function scatter() {
      playShatter();
      var letters = nameEl.querySelectorAll('.letter');
      letters.forEach(function(l) {
        var angle = Math.random() * Math.PI * 2;
        var dist = 60 + Math.random() * 140;
        var x = Math.cos(angle) * dist;
        var y = Math.sin(angle) * dist;
        var r = (Math.random() - 0.5) * 60;
        var s = 0.6 + Math.random() * 0.8;
        l.style.transform = 'translate(' + x + 'px,' + y + 'px) rotate(' + r + 'deg) scale(' + s + ')';
        l.style.opacity = (0.15 + Math.random() * 0.5).toString();
      });
      scattered = true;
    }

    function unscatter() {
      nameEl.querySelectorAll('.letter').forEach(function(l) {
        l.style.transform = '';
        l.style.opacity = '';
      });
      scattered = false;
    }

    /* Desktop: hover */
    nameEl.addEventListener('mouseenter', function() {
      clearTimeout(returnTimer);
      scatter();
    });
    nameEl.addEventListener('mouseleave', function() {
      unscatter();
    });

    /* Touch: tap to scatter, auto-return */
    nameEl.addEventListener('touchstart', function(e) {
      e.preventDefault();
      clearTimeout(returnTimer);
      if (scattered) {
        unscatter();
      } else {
        scatter();
        returnTimer = setTimeout(unscatter, 2500);
      }
    }, { passive: false });
  }

  /* ═══ BANNER 3D TILT + PARALLAX ═══ */
  if (!reducedMotion) {
    var bannerImg = document.querySelector('.hero-image img');
    var heroImage = document.querySelector('.hero-image');
    if (bannerImg && heroImage) {
      /* Parallax on scroll */
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            var scrollY = window.pageYOffset;
            var rect = heroImage.getBoundingClientRect();
            if (rect.bottom > 0) {
              bannerImg.style.transform = 'translateY(' + (scrollY * 0.08) + 'px)';
            }
            ticking = false;
          });
          ticking = true;
        }
      });

      /* 3D tilt on mousemove */
      if (window.matchMedia('(hover: hover)').matches) {
        heroImage.addEventListener('mousemove', function(e) {
          var rect = heroImage.getBoundingClientRect();
          var x = (e.clientX - rect.left) / rect.width - 0.5;
          var y = (e.clientY - rect.top) / rect.height - 0.5;
          bannerImg.style.transform = 'rotateY(' + (x * 6) + 'deg) rotateX(' + (-y * 4) + 'deg)';
          bannerImg.style.transition = 'transform 0.1s ease-out';
        });
        heroImage.addEventListener('mouseleave', function() {
          bannerImg.style.transform = '';
          bannerImg.style.transition = 'transform 0.6s ease-out';
        });
      }
    }
  }

  /* ═══ CARD TILT ═══ */
  if (!reducedMotion && window.matchMedia('(hover: hover)').matches) {
    document.querySelectorAll('.card').forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = 'translateY(-2px) rotateY(' + (x * 4) + 'deg) rotateX(' + (-y * 4) + 'deg)';
      });
      card.addEventListener('mouseleave', function() {
        card.style.transform = '';
      });
    });
  }

  /* ═══ AMBIENT SOUND ═══ */
  var audioCtx, gainNode, isPlaying = false;
  var soundBtn = document.getElementById('soundToggle');

  function createAmbient() {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    /* Two detuned sine waves — barely audible warmth */
    var osc1 = audioCtx.createOscillator();
    var osc2 = audioCtx.createOscillator();
    var osc3 = audioCtx.createOscillator();
    osc1.type = 'sine'; osc1.frequency.value = 85;
    osc2.type = 'sine'; osc2.frequency.value = 87.5;
    osc3.type = 'triangle'; osc3.frequency.value = 170;

    var filter = audioCtx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 300;
    filter.Q.value = 1;

    gainNode = audioCtx.createGain();
    gainNode.gain.value = 0;

    osc1.connect(filter);
    osc2.connect(filter);
    osc3.connect(filter);
    filter.connect(gainNode);
    gainNode.connect(audioCtx.destination);

    osc1.start();
    osc2.start();
    osc3.start();
  }

  if (soundBtn) {
    soundBtn.addEventListener('click', function() {
      if (!audioCtx) createAmbient();

      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      if (isPlaying) {
        gainNode.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.8);
        isPlaying = false;
        soundBtn.classList.remove('active');
      } else {
        gainNode.gain.linearRampToValueAtTime(0.025, audioCtx.currentTime + 1.5);
        isPlaying = true;
        soundBtn.classList.add('active');
      }
    });
  }
  /* ═══ LANGUAGE TOGGLE ═══ */
  var langBtn = document.getElementById('langToggle');
  var _saved = localStorage.getItem('jochenhornung-lang');
  var lang = _saved || ((navigator.language || 'de').toLowerCase().startsWith('de') ? 'de' : 'en');

  function updateLangBtn() {
    langBtn.textContent = lang.toUpperCase();
  }

  if (langBtn) {
    updateLangBtn();
    langBtn.addEventListener('click', function() {
      lang = lang === 'de' ? 'en' : 'de';
      localStorage.setItem('jochenhornung-lang', lang);
      updateLangBtn();
      /* i18n swap kommt später — für jetzt nur den State speichern */
    });
  }
})();
</script>
